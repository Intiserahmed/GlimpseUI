# ── AI Backend (OpenRouter — works with Gemini, Claude, GPT-4o, etc.) ─────────
# Get your key at https://openrouter.ai/keys
# Free models available: google/gemini-2.0-flash-exp:free, meta-llama/llama-3.2-11b-vision-instruct:free
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
# Comma-separated allowed CORS origins. Defaults to localhost only.
# Set this when deploying behind a custom domain:
# GLIMPSEUI_ALLOWED_ORIGINS=https://yourdomain.com

# ── Optional: lock down the server with an API key ────────────────────────────
# If set, all POST endpoints require:
#   Authorization: Bearer <key>   or   X-API-Key: <key>
# Leave empty to run open (local/dev mode).
GLIMPSEUI_API_KEY=
